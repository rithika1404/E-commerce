# Server Configuration
PORT=5000
NODE_ENV=development

# CORS - comma-separated frontend URLs allowed to make requests
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Database (for future use when switching from in-memory to a real DB)
# MONGO_URI=mongodb://localhost:27017/ecommerce
# DB_NAME=ecommerce

# JWT Secret (for future use when adding token-based auth)
# JWT_SECRET=your_super_secret_key_here
# JWT_EXPIRES_IN=7d
