# Vite Frontend Environment Variables
# All client-side variables MUST be prefixed with VITE_

# Backend API base URL.
# Leave empty for local Vite proxy, or set to your deployed backend URL in Vercel.
VITE_API_BASE_URL=

# App display name
VITE_APP_NAME=Meesho

# Port for the Vite dev server
VITE_PORT=3000
